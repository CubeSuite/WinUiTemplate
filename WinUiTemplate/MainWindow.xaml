<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="WinUiTemplate.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="using:CommunityToolkit.WinUI.Behaviors"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="using:WinUiTemplate"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:pages="using:WinUiTemplate.MVVM.Pages"
        xmlns:titlebar="using:WinUiTemplate.MVVM.Views.CustomTitleBar"
        Title="WinUiTemplate2"
        mc:Ignorable="d">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="rootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <titlebar:CustomTitleBar x:Name="titleBar" />

    </Grid>
</Window>
