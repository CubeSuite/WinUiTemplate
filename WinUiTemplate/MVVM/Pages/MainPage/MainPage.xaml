<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="WinUiTemplate.MVVM.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="using:WinUiTemplate.MVVM.Pages"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Grid>
        <NavigationView x:Name="navMenu"
                        IsBackButtonVisible="Collapsed"
                        IsPaneOpen="False"
                        IsPaneToggleButtonVisible="True"
                        ItemInvoked="OnNavigationViewItemInvoked">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Home Page"
                                    Icon="Home" />
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Backups"
                                    Icon="Save"
                                    Visibility="{Binding BackupsButtonVisibility}" />
            </NavigationView.FooterMenuItems>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <ItemsRepeater ItemsSource="{Binding Notifications}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <InfoBar Title="{Binding Title}"
                                     IsOpen="True"
                                     Message="{Binding Message}"
                                     Severity="{Binding Severity}">
                                <InfoBar.ActionButton>
                                    <Button Content="{Binding ButtonText}"
                                            Command="{Binding ActionButtonClickedCommand}"
                                            Visibility="{Binding ActionButtonVisibility}" />
                                </InfoBar.ActionButton>
                            </InfoBar>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
                <Frame x:Name="pageFrame"
                       Grid.Row="1" />

            </Grid>
        </NavigationView>

    </Grid>
</Page>
