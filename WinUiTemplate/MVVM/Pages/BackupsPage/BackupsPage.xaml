<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="WinUiTemplate.MVVM.Pages.BackupsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="using:WinUiTemplate.MVVM.Pages"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Grid>
        <ScrollViewer>
            <ItemsRepeater ItemsSource="{Binding Backups}"
                           Margin="16">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical"
                                 Spacing="16" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8">
                            <Grid Margin="8"
                                  ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding Timestamp}"
                                           VerticalAlignment="Center" />

                                <TextBlock Text="{Binding CreatedWith}"
                                           Grid.Column="1"
                                           VerticalAlignment="Center" />

                                <TextBlock Text="{Binding Size}"
                                           Grid.Column="2"
                                           VerticalAlignment="Center" />

                                <Button Content="{Binding RestoreButtonText}"
                                        Grid.Column="3"
                                        Command="{Binding RestoreCommand}" />
                                <Button Content="Delete"
                                        Grid.Column="4"
                                        Command="{Binding DeleteCommand}" />

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>
    </Grid>
</Page>
