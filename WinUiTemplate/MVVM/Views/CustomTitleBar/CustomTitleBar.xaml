<?xml version="1.0" encoding="utf-8" ?>
<UserControl x:Class="WinUiTemplate.MVVM.Views.CustomTitleBar.CustomTitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="using:WinUiTemplate.MVVM.Views.CustomTitleBar"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <StackPanel Height="48"
                Orientation="Horizontal">
        <AppBarButton Width="48"
                      Padding="0"
                      Background="Transparent"
                      Command="{Binding ToggleThemeCommand}"
                      ToolTipService.ToolTip="Toggle Dark Mode">
            <AppBarButton.Icon>
                <FontIcon Glyph="{Binding ThemeIcon}"
                          FontSize="16"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />
            </AppBarButton.Icon>
        </AppBarButton>

        <TextBlock Text="{Binding ProgramName}"
                   VerticalAlignment="Center" />
        <TextBlock Text="{Binding ProgramVersion}"
                   Margin="16,0,0,0"
                   VerticalAlignment="Center"
                   Opacity="0.5" />

    </StackPanel>

</UserControl>
