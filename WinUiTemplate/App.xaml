<?xml version="1.0" encoding="utf-8" ?>
<Application x:Class="WinUiTemplate.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:WinUiTemplate">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!--  Other merged dictionaries here  -->
                <ResourceDictionary>
                    <Color x:Key="SystemAccentColor">#FFFFFFFF</Color>
                    <Color x:Key="SystemAccentColorLight1">#FFFFFFFF</Color>
                    <Color x:Key="SystemAccentColorLight2">#FFFFFFFF</Color>
                    <Color x:Key="SystemAccentColorLight3">#FFFFFFFF</Color>
                    <Color x:Key="SystemAccentColorDark1">#FFFFFFFF</Color>
                    <Color x:Key="SystemAccentColorDark2">#FFFFFFFF</Color>
                    <Color x:Key="SystemAccentColorDark3">#FFFFFFFF</Color>
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
            <!--  Other app resources here  -->
        </ResourceDictionary>
    </Application.Resources>
</Application>
